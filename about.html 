    <style>
        /* ==========================================================================
           ABOUT PAGE SPECIFIC STYLES
           ========================================================================== */
        .about-hero {
            padding: 6rem 2rem 4rem 2rem;
            max-width: 1200px;
            margin: 0 auto;
            text-align: center;
        }

        .about-story {
            padding: 4rem 2rem;
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: center;
        }

        .story-content h2 {
            font-size: 2.2rem;
            font-weight: 800;
            margin-bottom: 1.5rem;
        }

        .story-content p {
            color: var(--text-muted);
            font-size: 1.1rem;
            margin-bottom: 1.5rem;
        }

        /* Technical Values Section */
        .values-section {
            background-color: var(--bg-card);
            border-top: 1px solid var(--border-color);
            border-bottom: 1px solid var(--border-color);
            padding: 6rem 2rem;
        }

        .values-container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .values-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2.5rem;
            margin-top: 4rem;
        }

        .value-card {
            background-color: var(--bg-dark);
            border: 1px solid var(--border-color);
            padding: 2.5rem 2rem;
            border-radius: 12px;
            transition: transform var(--transition-speed) ease;
        }

        .value-card:hover {
            transform: translateY(-5px);
            border-color: rgba(229, 169, 60, 0.3);
        }

        .value-card i {
            font-size: 2.2rem;
            color: var(--accent-gold);
            margin-bottom: 1.5rem;
        }

        .value-card h3 {
            font-size: 1.3rem;
            font-weight: 700;
            margin-bottom: 1rem;
        }

        .value-card p {
            color: var(--text-muted);
            font-size: 0.95rem;
        }

        /* --- Tech Stack Badges --- */
        .tech-badges {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            margin-top: 2rem;
        }

        .badge {
            background-color: rgba(229, 169, 60, 0.1);
            border: 1px solid rgba(229, 169, 60, 0.2);
            color: var(--accent-gold);
            padding: 0.4rem 1rem;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
        }

        /* Responsive Breakpoints */
        @media (max-width: 968px) {
            .about-story {
                grid-template-columns: 1fr;
                text-align: center;
                gap: 3rem;
            }
            .values-grid {
                grid-template-columns: 1fr;
            }
            .tech-badges {
                justify-content: center;
            }
        }
    </style>
</head>
