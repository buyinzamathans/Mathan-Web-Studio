    <style>
        /* ==========================================================================
           SERVICES PAGE SPECIFIC STYLES
           ========================================================================== */
        .services-hero {
            padding: 6rem 2rem 4rem 2rem;
            max-width: 1200px;
            margin: 0 auto;
            text-align: center;
        }

        .services-grid {
            max-width: 1200px;
            margin: 0 auto 6rem auto;
            padding: 0 2rem;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2.5rem;
        }

        .service-page-card {
            background-color: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 3rem 2rem;
            display: flex;
            flex-direction: column;
            transition: transform var(--transition-speed) ease, border-color var(--transition-speed) ease;
        }

        .service-page-card:hover {
            transform: translateY(-5px);
            border-color: rgba(229, 169, 60, 0.4);
        }

        .service-icon-box {
            width: 60px;
            height: 60px;
            background-color: rgba(229, 169, 60, 0.1);
            border: 1px solid rgba(229, 169, 60, 0.2);
            border-radius: 12px;
            display: flex;
            justify-content: center;
            align-items: center;
            margin-bottom: 2rem;
        }

        .service-icon-box i {
            font-size: 1.8rem;
            color: var(--accent-gold);
        }

        .service-page-card h3 {
            font-size: 1.4rem;
            font-weight: 700;
            margin-bottom: 1rem;
        }

        .service-page-card p {
            color: var(--text-muted);
            font-size: 0.95rem;
            line-height: 1.6;
            margin-bottom: 2rem;
        }

        .service-features {
            list-style: none;
            margin-top: auto; /* Pushes features to the bottom to align them across cards */
            padding-top: 1.5rem;
            border-top: 1px solid var(--border-color);
        }

        .service-features li {
            font-size: 0.9rem;
            color: var(--text-main);
            margin-bottom: 0.75rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .service-features li i {
            color: var(--accent-gold);
            font-size: 0.85rem;
        }

        /* Technical Stack Section */
        .tech-overview {
            background-color: var(--bg-card);
            border-top: 1px solid var(--border-color);
            padding: 6rem 2rem;
            text-align: center;
        }

        .tech-row {
            max-width: 800px;
            margin: 3rem auto 0 auto;
            display: flex;
            justify-content: center;
            gap: 3rem;
            flex-wrap: wrap;
        }

        .tech-item {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            font-weight: 600;
            color: var(--text-muted);
        }

        .tech-item i {
            color: var(--accent-gold);
        }

        /* Responsive Breakpoints */
        @media (max-width: 968px) {
            .services-grid {
                grid-template-columns: 1fr;
                gap: 2rem;
            }
        }
    </style>
</head>
